# Application
APP_ENV=local
PORT=4000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://aim_user:aim_password@127.0.0.1:5433/aim_tank_integrity
DB_SSL=false
DB_POOL_MAX=10

# Auth / JWT
# AUTH_JWT_SECRET signs AIM access/refresh tokens. Production-like environments must provide a strong secret.
AUTH_JWT_SECRET=replace-with-local-dev-secret-at-least-32-chars
AUTH_TOKEN_ISSUER=aim-api-local
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_REQUIRE_STRONG_SECRET_IN_PRODUCTION=true

# Local demo auth is only for local/development/test. It is ignored in production-like environments.
AUTH_ALLOW_LOCAL_DEMO=true
AUTH_LOCAL_DEMO_PASSWORD=ChangeMe123!

# Object Storage Compatible Settings - required for future RC3-B evidence/report artifact flows.
OBJECT_STORAGE_PROVIDER=s3-compatible
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=aim-evidence-local
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_PUBLIC_BASE_URL=http://localhost:9000
OBJECT_STORAGE_SIGNED_URL_TTL_SECONDS=900
EVIDENCE_MAX_FILE_SIZE_BYTES=104857600
EVIDENCE_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,text/csv,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
EVIDENCE_ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png,.csv,.xlsx

# n8n Webhook URLs - n8n calls AIM backend APIs only; these URLs are notification/orchestration hooks.
N8N_FILE_INTAKE_WEBHOOK_URL=http://localhost:5678/webhook/aim-file-intake
N8N_VALIDATION_NOTIFICATION_WEBHOOK_URL=http://localhost:5678/webhook/aim-validation-notification
N8N_REVIEW_NOTIFICATION_WEBHOOK_URL=http://localhost:5678/webhook/aim-review-notification
N8N_REPORT_GENERATION_WEBHOOK_URL=http://localhost:5678/webhook/aim-report-generation
N8N_ERROR_QUEUE_WEBHOOK_URL=http://localhost:5678/webhook/aim-error-queue

# Report Generator
REPORT_GENERATOR_BASE_URL=http://localhost:4100
REPORT_GENERATOR_API_KEY=replace-with-local-report-generator-key
REPORT_TEMPLATE_BUCKET=aim-report-templates-local
REPORT_OUTPUT_BUCKET=aim-report-output-local
REPORT_DEFAULT_TEMPLATE_ID=tank-integrity-mvp-v1
REPORT_GENERATION_TIMEOUT_SECONDS=120
